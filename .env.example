# Required: your aprs.fi API key (free — get one at https://aprs.fi/ after logging in)
APRS_API_KEY=your_aprs_fi_api_key_here

# Optional: MapTiler API key for the MapTiler Outdoor layer
# Free tier: 100k tiles/month — https://www.maptiler.com/
# If omitted, MapTiler Outdoor layer will not appear in the map.
MAPTILER_API_KEY=

# Your callsign — used as the default search and in the User-Agent header sent to aprs.fi
OPERATOR_CALLSIGN=KH7AL

# Server-side cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL=300
